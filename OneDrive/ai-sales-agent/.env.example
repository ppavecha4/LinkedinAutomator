══ ANTHROPIC ═══════════════════════════════
ANTHROPIC_API_KEY=                    # console.anthropic.com → API Keys
══ AWS ══════════════════════════════════════
AWS_ACCESS_KEY_ID=                    # IAM user with programmatic access
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
══ EMAIL — provider switch ═══════════════════
# Pick the email backend. Options:
#   google_workspace  → SMTP relay via smtp.gmail.com:587 with App Password
#                       (recommended for new operators — 5-min setup,
#                       inherits your mailbox reputation)
#   ses               → Amazon SES v2 via boto3 (production-scale path)
# If unset, auto-detects from which credentials are populated below.
EMAIL_PROVIDER=google_workspace

══ EMAIL — Google Workspace SMTP ═════════════
GOOGLE_WORKSPACE_EMAIL=               # you@your-workspace-domain.com
GOOGLE_WORKSPACE_APP_PASSWORD=        # 16-char from myaccount.google.com/apppasswords
GOOGLE_WORKSPACE_FROM_NAME=           # "First Last" — display name on outbound
GOOGLE_WORKSPACE_REPLY_TO=            # optional; defaults to GOOGLE_WORKSPACE_EMAIL

# Email open tracking (opt-in — keep OFF for cold first-touch sends
# to preserve deliverability; turn ON for warm replies / follow-ups
# to known engaged contacts where 3–5% extra spam risk is acceptable).
# The pixel hits {EMAIL_TRACKING_BASE_URL}/track/open/{message_id}.gif
# which MUST be publicly reachable — Gmail can't fetch localhost.
# For local dev use a cloudflared tunnel to expose the API.
EMAIL_TRACK_OPENS=false               # true | false
EMAIL_TRACKING_BASE_URL=              # e.g. https://abc123.trycloudflare.com

══ EMAIL — Amazon SES (alternative) ══════════
SES_FROM_EMAIL=                       # Verified sender in SES console
SES_FROM_NAME=                        # Display name
SES_CONFIGURATION_SET=sales-agent     # Created by deploy script
UNSUBSCRIBE_BASE_URL=                 # https://yourdomain.com (used by both providers)
══ WHATSAPP — Twilio ═════════════════════════
TWILIO_ACCOUNT_SID=                   # console.twilio.com
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=                 # whatsapp:+14155238886
TWILIO_WEBHOOK_URL=                   # Set after first deploy
══ LINKEDIN — channel mode ═══════════════════
# draft     → operator manually click-sends from the LinkedIn Drafts
#             queue. Works with ANY LinkedIn account. Default.
# heyreach  → delegate to Heyreach Sales (browser automation SaaS).
#             Real automation, $50–200/mo, no MDP review needed.
# api       → direct LinkedIn Sales Navigator API. Requires Marketing
#             Developer Platform partnership (4–8 wk review, gated).
LINKEDIN_MODE=draft

══ LINKEDIN — API mode (when MDP-approved) ═══
LINKEDIN_CLIENT_ID=                   # LinkedIn Developer Portal
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=                # OAuth2 — see docs/linkedin-setup.md
LINKEDIN_PERSON_URN=                  # urn:li:person:XXXXXXXX

══ LINKEDIN — Heyreach mode (SaaS automation) ═
# Public API key from your Heyreach account settings.
HEYREACH_API_KEY=
# Default campaign id for first-touch (connection requests). Operator
# pre-configures this campaign in Heyreach with body template that
# references {{customField1}} so our AI-personalised text is used verbatim.
HEYREACH_CAMPAIGN_ID=
# Optional: separate campaign id used when send_message() fires the
# follow-up DM. If unset, falls back to HEYREACH_CAMPAIGN_ID — your
# Heyreach sequence should then cover both steps.
HEYREACH_CAMPAIGN_ID_FOLLOWUP=

# Optional: when set, POST /api/campaigns auto-creates a matching
# Heyreach campaign by CLONING this template (uses Heyreach's
# /campaign/CreateCampaignFromTemplate endpoint). The template should
# have your sequence, LinkedIn account, and {{customField1}} body
# template pre-configured in the Heyreach UI. Leave empty to skip
# templated clone — auto-create will fall back to a blank campaign,
# which means you'll need to finish sequence config in Heyreach UI
# before pushing leads.
HEYREACH_TEMPLATE_CAMPAIGN_ID=
══ PROSPECT ENRICHMENT ════════════════════════
APOLLO_API_KEY=                       # app.apollo.io → Settings → API Keys
══ MEETING BOOKING ════════════════════════════
CALENDLY_API_KEY=                     # calendly.com/integrations/api
CALENDLY_EVENT_TYPE_URI=              # Full URI of your event type
CALENDLY_WEBHOOK_SIGNING_KEY=
══ DATABASE (auto-set by CDK — leave blank) ══
DATABASE_URL=
REDIS_URL=
══ AUTH — Cognito (auto-set by CDK) ══════════
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-south-1
══ APP ════════════════════════════════════════
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
DASHBOARD_PORT=5173
